# MedCampus — variáveis de ambiente (exemplo). Copie para .env.local e preencha.
# NUNCA commitar .env.local. Todos os segredos ficam SÓ no servidor.

# ── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=            # server-only (ignora RLS) — nunca no client

# ── Admin (Editora Médica e /admin) ─────────────────────────────────────────
ADMIN_PASSWORD=                        # senha única do admin (cookie = sha256)

# ── IA — OpenAI (assistente RAG, agentes, revisão da Editora) ───────────────
OPENAI_API_KEY=
OPENAI_REVIEW_MODEL=gpt-4o             # (opcional) modelo do estágio de revisão

# ── IA — DeepSeek (geração da Editora) ──────────────────────────────────────
DEEPSEEK_API_KEY=                      # necessário quando AI_PROVIDER=real
DEEPSEEK_MODEL=deepseek-chat           # (opcional) default deepseek-chat

# ── Editora — seleção de provider ───────────────────────────────────────────
# mock  = IA simulada (dev, sem custo)   |   real = DeepSeek (geração) + GPT-4o (revisão)
AI_PROVIDER=mock

# ── PubMed (módulos de retrieval: Atualizador, Comparador, Pesquisador) ──────
PUBMED_API_KEY=                        # (opcional) aumenta o rate limit do E-utilities

# ── Vercel Blob (conteúdo editável do site) ─────────────────────────────────
BLOB_READ_WRITE_TOKEN=

# ── Cron (rotas /api/agents/*) ──────────────────────────────────────────────
CRON_SECRET=

# ── E-mail (Resend) ─────────────────────────────────────────────────────────
RESEND_API_KEY=
RELATORIO_EMAIL=                       # destinatário do relatório de melhoria

# ── Web Push (PWA) ──────────────────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
